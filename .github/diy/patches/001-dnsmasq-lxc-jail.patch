--- a/dnsmasq/files/dnsmasq.init
+++ b/dnsmasq/files/dnsmasq.init
@@ -1259,6 +1259,14 @@ dnsmasq_start()
 	esac
 
 	procd_open_instance
+
+	# LXC 容器内跳过 procd jail（AppArmor/mount namespace 被拦截 → crash loop）
+	# 跳过 jail 不影响 dnsmasq 功能，只是无沙箱隔离
+	if grep -qE 'lxc|container' /proc/1/cgroup 2>/dev/null ||
+	   [ -f /.lxc ] || [ -f /run/lxc ] || [ -d /dev/lxc ]; then
+		procd_close_instance
+		return
+	fi
 	procd_add_jail dnsmasq ubus log
 	procd_add_jail_mount $CONFIGFILE $DHCPBOGUSHOSTNAMEFILE $DHCPSCRIPT $DHCPSCRIPT_DEPENDS
 	procd_add_jail_mount $EXTRA_MOUNT $RFC6761FILE $TRUSTANCHORSFILE
