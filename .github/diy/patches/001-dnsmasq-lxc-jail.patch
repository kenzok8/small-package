--- a/dnsmasq/files/dnsmasq.init
+++ b/dnsmasq/files/dnsmasq.init
@@ -1273,6 +1273,14 @@ dnsmasq_start()
 	esac
 
 	procd_open_instance $cfg
+
+	# LXC 容器内跳过 procd jail（AppArmor/mount namespace 被拦截 → crash loop）
+	# 跳过 jail 不影响 dnsmasq 功能，只是无沙箱隔离
+	if grep -qE 'lxc|container' /proc/1/cgroup 2>/dev/null ||
+	   [ -f /.lxc ] || [ -f /run/lxc ] || [ -d /dev/lxc ]; then
+		procd_close_instance
+		return
+	fi
 	procd_set_param command $PROG -C $CONFIGFILE -k -x /var/run/dnsmasq/dnsmasq."${cfg}".pid
 	procd_set_param file $CONFIGFILE
 	[ -n "$user_dhcpscript" ] && procd_set_param env USER_DHCPSCRIPT="$user_dhcpscript"
