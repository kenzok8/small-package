# ---- config.js: daede Settings ----
msgid "daede Settings"
msgstr "daede 设置"

msgid "A modern dashboard for dae. Subscriptions, nodes, routing and DNS are managed in the daed WebUI."
msgstr "dae 的现代化控制台。订阅、节点、路由和 DNS 请在 daed WebUI 中管理。"

